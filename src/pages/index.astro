---
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<div class="home-content">
		<div class="hero">
			<img
				src="/images/avatar.webp"
				alt={`Avatar of ${SITE_TITLE}`}
				width="200"
				height="200"
				class="avatar"
			/>
			<h1>{SITE_TITLE}</h1>
			<p class="tagline">{SITE_TAGLINE}</p>
			<p class="hero-cta">
				<a class="cta-link" href="/contact/">Get in touch</a>
			</p>
		</div>
	</div>
</BaseLayout>

<style>
	:global(#main-content:has(> .home-content)) {
		display: flex;
		flex-direction: column;
		flex: 1 0 auto;
		min-height: 0;
	}

	.home-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		width: 100%;
		padding-block: clamp(1rem, 4vh, 2.5rem);
		box-sizing: border-box;
	}

	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 0 1rem;
		max-width: 32rem;
	}
	.avatar {
		width: 160px;
		height: 160px;
		border-radius: 50%;
		margin-bottom: 1.5rem;
		border: 3px solid var(--border);
		object-fit: cover;
	}
	.hero h1 {
		font-size: 2.5rem;
		margin: 0 0 0.25rem;
	}
	.tagline {
		font-size: 1.15rem;
		color: var(--foreground-muted);
		margin: 0 0 1.25rem;
		font-style: italic;
	}
	.hero-cta {
		margin: 0;
		font-size: 1rem;
	}
	@media (max-width: 720px) {
		.home-content {
			padding-block: clamp(0.75rem, 3vh, 1.5rem);
		}
		.avatar {
			width: 120px;
			height: 120px;
		}
		.hero h1 {
			font-size: 2rem;
		}
	}
</style>
