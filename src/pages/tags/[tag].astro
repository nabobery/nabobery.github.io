---
import { type CollectionEntry, getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  buildTagIndexFromCollections,
  entriesWithTagSlug,
  sortByPubDateDesc,
  type TagStat,
} from '../../lib/tag-utils';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const projects = await getCollection('projects');
  const index = buildTagIndexFromCollections(blogPosts, projects);
  return [...index.values()]
    .filter((stat) => stat.slug.length > 0)
    .map((stat) => ({
      params: { tag: stat.slug },
      props: {
        stat,
        posts: sortByPubDateDesc(entriesWithTagSlug(blogPosts, stat.slug)),
        projects: sortByPubDateDesc(entriesWithTagSlug(projects, stat.slug)),
      },
    }));
}

type Props = {
  stat: TagStat;
  posts: CollectionEntry<'blog'>[];
  projects: CollectionEntry<'projects'>[];
};

const { stat, posts, projects } = Astro.props;
const description = posts.length === 0 && projects.length === 0
  ? `Content tagged “${stat.displayLabel}”.`
  : `${posts.length} post${posts.length === 1 ? '' : 's'}, ${projects.length} project${projects.length === 1 ? '' : 's'} tagged “${stat.displayLabel}”.`;
---

<BaseLayout
	title={`Tag: ${stat.displayLabel} · ${SITE_TITLE}`}
	description={description}
>
	<div class="tag-detail-page">
		<h1 class="page-title">Tag: {stat.displayLabel}</h1>

		{
			posts.length > 0 && (
				<section class="tag-section" aria-labelledby="posts-heading">
					<h2 id="posts-heading" class="section-title">
						Blog
					</h2>
					<ul class="item-list">
						{posts.map((post) => (
							<li>
								<a href={`/posts/${post.id}/`} class="item-card">
									<span class="item-title">{post.data.title}</span>
									<span class="item-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))}
					</ul>
				</section>
			)
		}

		{
			projects.length > 0 && (
				<section class="tag-section" aria-labelledby="projects-heading">
					<h2 id="projects-heading" class="section-title">
						Projects
					</h2>
					<ul class="item-list">
						{projects.map((p) => (
							<li>
								<a href={`/projects/${p.id}/`} class="item-card">
									<span class="item-title">{p.data.title}</span>
									<span class="item-date">
										<FormattedDate date={p.data.pubDate} />
									</span>
								</a>
							</li>
						))}
					</ul>
				</section>
			)
		}

		{
			posts.length === 0 && projects.length === 0 && (
				<p class="empty">
					No content for this tag. <a href="/tags/">All tags</a>
				</p>
			)
		}
	</div>
</BaseLayout>

<style>
	.tag-detail-page {
		max-width: var(--content-wide);
		margin: 0 auto;
		padding: 1.5rem 1rem 3rem;
	}
	.page-title {
		text-align: center;
		margin-bottom: 2rem;
	}
	.tag-section {
		margin-bottom: 2.5rem;
	}
	.tag-section:last-of-type {
		margin-bottom: 0;
	}
	.section-title {
		font-size: 1.1rem;
		font-weight: 600;
		margin: 0 0 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border);
		color: var(--foreground);
	}
	.item-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
	}
	.item-card {
		display: block;
		padding: 1rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		text-decoration: none;
		color: var(--foreground);
		transition:
			box-shadow 0.2s ease,
			border-color 0.2s ease;
	}
	.item-card:hover {
		box-shadow: var(--box-shadow);
		border-color: var(--accent);
	}
	.item-card:hover .item-title {
		color: var(--accent);
	}
	.item-title {
		display: block;
		font-weight: 600;
		font-size: 1rem;
		line-height: 1.3;
		margin-bottom: 0.5rem;
		transition: color 0.15s ease;
	}
	.item-date {
		display: block;
		font-size: 0.85rem;
		color: var(--foreground-muted);
	}
	.empty {
		text-align: center;
		color: var(--foreground-muted);
	}
</style>
