---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from './BaseLayout.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	authors,
	tags,
	categories,
} = Astro.props;
---

<BaseLayout {title} {description}>
	<article class="blog-post">
		{heroImage && (
			<div class="hero-image">
				<Image width={1020} height={510} src={heroImage} alt={title} />
			</div>
		)}
		<div class="prose">
			<header class="post-header">
				<div class="date">
					<FormattedDate date={pubDate} />
					{updatedDate && (
						<span class="last-updated-on">
							&middot; Updated <FormattedDate date={updatedDate} />
						</span>
					)}
				</div>
				<h1>{title}</h1>
				{(authors?.length || tags?.length || categories?.length) && (
					<p class="meta-line">
						{authors?.length ? <span>{authors.join(', ')}</span> : null}
						{tags?.length ? <span> · {tags.join(', ')}</span> : null}
						{categories?.length ? <span> · {categories.join(', ')}</span> : null}
					</p>
				)}
				<hr />
			</header>
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	.blog-post {
		width: 100%;
	}
	.hero-image {
		max-width: var(--content-wide);
		margin: 0 auto 2rem;
		padding: 0 1rem;
	}
	.hero-image img {
		display: block;
		width: 100%;
		border-radius: var(--radius);
		box-shadow: var(--box-shadow);
	}
	.post-header {
		margin-bottom: 1.5rem;
		padding-bottom: 0;
		text-align: center;
		line-height: 1.2;
	}
	.post-header h1 {
		margin: 0 0 0.5em;
	}
	.date {
		margin-bottom: 0.5em;
		color: var(--foreground-muted);
		font-size: 0.9rem;
	}
	.last-updated-on {
		font-style: italic;
	}
	.meta-line {
		margin: 0.5rem 0 0;
		font-size: 0.875rem;
		color: var(--foreground-muted);
	}
</style>
