---
import { SITE_TITLE } from '../consts';
import { MAIN_NAV } from '../site.config';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<a class="site-name" href="/">{SITE_TITLE}</a>
		<div class="nav-right">
			<div class="internal-links">
				{
					MAIN_NAV.map((item) => (
						<HeaderLink href={item.href}>{item.label}</HeaderLink>
					))
				}
			</div>
			<ThemeToggle />
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0 1.25rem;
		background-color: var(--surface);
		border-bottom: 1px solid var(--border);
	}
	.site-name {
		font-weight: 700;
		font-size: 1.05rem;
		text-decoration: none;
		color: var(--foreground);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.site-name:hover {
		color: var(--accent);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: var(--content-wide);
		margin: 0 auto;
		height: 3.5rem;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-shrink: 0;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.internal-links :global(a) {
		padding: 0.5em 0.5em;
		color: var(--foreground-muted);
		font-size: 0.95rem;
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.internal-links :global(a:hover) {
		color: var(--foreground);
	}
	.internal-links :global(a.active) {
		color: var(--foreground);
		font-weight: 600;
	}
	@media (max-width: 720px) {
		.internal-links {
			gap: 0;
		}
		.internal-links :global(a) {
			padding: 0.5em 0.35em;
			font-size: 0.85rem;
		}
	}
</style>
