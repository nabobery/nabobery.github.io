---
---

<button
	id="theme-toggle"
	aria-label="Toggle dark mode"
	title="Toggle dark mode"
	type="button"
>
	<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<circle cx="12" cy="12" r="5" />
		<line x1="12" y1="1" x2="12" y2="3" />
		<line x1="12" y1="21" x2="12" y2="23" />
		<line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
		<line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
		<line x1="1" y1="12" x2="3" y2="12" />
		<line x1="21" y1="12" x2="23" y2="12" />
		<line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
		<line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
	</svg>
	<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
	</svg>
</button>

<style>
	#theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		padding: 0;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		background: transparent;
		color: var(--foreground-muted);
		cursor: pointer;
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	#theme-toggle:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	:global([data-theme="dark"]) .icon-sun {
		display: block;
	}
	:global([data-theme="dark"]) .icon-moon {
		display: none;
	}
	:global([data-theme="light"]) .icon-sun {
		display: none;
	}
	:global([data-theme="light"]) .icon-moon {
		display: block;
	}
	/* Before JS loads, hide both and show based on system preference */
	:global(:not([data-theme])) .icon-sun {
		display: none;
	}
	:global(:not([data-theme])) .icon-moon {
		display: block;
	}
</style>

<script is:inline>
	function getThemePreference() {
		if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
			return localStorage.getItem("theme");
		}
		return window.matchMedia("(prefers-color-scheme: dark)").matches
			? "dark"
			: "light";
	}

	function applyTheme(theme) {
		document.documentElement.setAttribute("data-theme", theme);
	}

	function themeToggleClickHandler() {
		var current = document.documentElement.getAttribute("data-theme");
		var next = current === "dark" ? "light" : "dark";
		applyTheme(next);
		if (typeof localStorage !== "undefined") {
			localStorage.setItem("theme", next);
		}
	}

	function initThemeToggle() {
		const toggle = document.getElementById("theme-toggle");
		if (!(toggle instanceof HTMLButtonElement)) return;
		toggle.removeEventListener("click", themeToggleClickHandler);
		toggle.addEventListener("click", themeToggleClickHandler);
	}

	applyTheme(getThemePreference());
	initThemeToggle();

	document.addEventListener("astro:after-swap", function () {
		applyTheme(getThemePreference());
		initThemeToggle();
	});
</script>
